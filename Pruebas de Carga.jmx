<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Pruebas de carga" enabled="true">
      <stringProp name="TestPlan.comments"></stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
      <stringProp name="TestPlan.user_define_classpath"></stringProp>
    </TestPlan>
    <hashTree>
      <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="Variables">
        <collectionProp name="Arguments.arguments">
          <elementProp name="ip_postgres" elementType="Argument">
            <stringProp name="Argument.name">ip_postgres</stringProp>
            <stringProp name="Argument.value">3.87.247.152</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Dirección IP pública de la máquina EC2 con el servidor de postgres</stringProp>
          </elementProp>
          <elementProp name="ip_timescale" elementType="Argument">
            <stringProp name="Argument.name">ip_timescale</stringProp>
            <stringProp name="Argument.value">3.83.235.146</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Dirección IP pública de la máquina EC2 con el servidor de timescale</stringProp>
          </elementProp>
          <elementProp name="puerto" elementType="Argument">
            <stringProp name="Argument.name">puerto</stringProp>
            <stringProp name="Argument.value">8000</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Puerto del servidor que recibe las peticiones HTTP</stringProp>
          </elementProp>
          <elementProp name="endpoint_path" elementType="Argument">
            <stringProp name="Argument.name">endpoint_path</stringProp>
            <stringProp name="Argument.value">/analytics/stationSummary/</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Endpoint nuevo de resumen por estacion</stringProp>
          </elementProp>
          <elementProp name="measurement_name" elementType="Argument">
            <stringProp name="Argument.name">measurement_name</stringProp>
            <stringProp name="Argument.value">Temperatura</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Filtro opcional de medicion</stringProp>
          </elementProp>
          <elementProp name="from_epoch_ms" elementType="Argument">
            <stringProp name="Argument.name">from_epoch_ms</stringProp>
            <stringProp name="Argument.value">1625115600000</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Fecha inicial epoch en milisegundos</stringProp>
          </elementProp>
          <elementProp name="to_epoch_ms" elementType="Argument">
            <stringProp name="Argument.name">to_epoch_ms</stringProp>
            <stringProp name="Argument.value">1627793999999</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Fecha final epoch en milisegundos</stringProp>
          </elementProp>
          <elementProp name="query_limit" elementType="Argument">
            <stringProp name="Argument.name">query_limit</stringProp>
            <stringProp name="Argument.value">10</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Limite de estaciones en el ranking</stringProp>
          </elementProp>
          <elementProp name="consulta_url" elementType="Argument">
            <stringProp name="Argument.name">consulta_url</stringProp>
            <stringProp name="Argument.value">${endpoint_path}?measurement=${measurement_name}&amp;from=${from_epoch_ms}&amp;to=${to_epoch_ms}&amp;limit=${query_limit}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">URL de la consulta agregada</stringProp>
          </elementProp>
        </collectionProp>
        <stringProp name="TestPlan.comments">Editar según los datos de su despliegue</stringProp>
      </Arguments>
      <hashTree/>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Postgres" enabled="true">
        <intProp name="ThreadGroup.num_threads">60</intProp>
        <intProp name="ThreadGroup.ramp_time">1</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Petición a postgres">
          <stringProp name="HTTPSampler.domain">${ip_postgres}</stringProp>
          <stringProp name="HTTPSampler.port">${puerto}</stringProp>
          <stringProp name="HTTPSampler.path">${consulta_url}</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="Variables definidas por el Usuario">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree/>
